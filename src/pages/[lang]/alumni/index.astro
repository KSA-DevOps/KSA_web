---
import BaseLayout from "@layout/BaseLayout.astro";
import { getCollection } from "astro:content";
import { getTranslation } from "@utils/i18n";

export function getStaticPaths() {
  return [
    { params: { lang: 'ko' } },
    { params: { lang: 'en' } }
  ];
}

const { lang } = Astro.params;
const currentLang: 'ko' | 'en' = (lang === 'ko' || lang === 'en') ? lang : 'ko';

const allAlumni = await getCollection('alumni');
const filteredAlumni = allAlumni.filter(item => item.data.display !== false);
const sortedAlumni = [...filteredAlumni].sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<BaseLayout lang={currentLang}>
  <div class="min-h-screen bg-gradient-to-br from-teal-50 to-blue-50">
    <section class="relative py-20">
      <div class="container mx-auto px-4 text-center pt-header">
        <h1 class="text-5xl font-bold text-gray-800 mb-6">
          {getTranslation("alumni.title", currentLang)}
        </h1>
        <p class="text-xl text-gray-600 max-w-3xl mx-auto mb-8">
          {getTranslation("alumni.subtitle", currentLang)}
        </p>
      </div>
    </section>

    <section class="py-16 bg-gray-50">
      <div class="container mx-auto px-4">
        {sortedAlumni.length === 0 ? (
          <div class="text-center py-20">
            <p class="text-xl text-gray-500">{currentLang === 'ko' ? '등록된 동문 소식이 없습니다.' : 'No alumni updates yet.'}</p>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 max-w-6xl mx-auto">
            {sortedAlumni.map((item) => (
              <a href={`/${currentLang}/alumni/${item.id}`} class="group">
                <div class="bg-white rounded-xl shadow-lg overflow-hidden hover:shadow-xl transition-all duration-300 transform hover:scale-105 h-full flex flex-col">
                  <div class="p-6 flex flex-col flex-grow">
                    <div class="flex items-center mb-4">
                      <span class="text-3xl mr-3">{item.data.icon || '🎓'}</span>
                      <div>
                        <h3 class="text-lg font-semibold text-gray-800 mb-1 group-hover:text-teal-600 transition-colors">{item.data.title}</h3>
                        <p class="text-sm text-gray-500">
                          {item.data.date.toLocaleDateString(currentLang === 'ko' ? 'ko-KR' : 'en-US', {
                            year: 'numeric',
                            month: 'short',
                            day: 'numeric'
                          })}
                        </p>
                      </div>
                    </div>
                    <p class="text-gray-600 mb-4 flex-grow">{item.data.description}</p>
                    <div class="flex justify-between items-center mt-auto">
                      <span class={`inline-block px-3 py-1 rounded-full text-xs font-medium text-white ${item.data.isNewsletter ? 'bg-indigo-500' : 'bg-teal-500'}`}>
                        {item.data.isNewsletter ? (currentLang === 'ko' ? '뉴스레터' : 'Newsletter') : (currentLang === 'ko' ? '소식' : 'Update')}
                      </span>
                      <span class="text-teal-600 group-hover:text-teal-800 text-sm font-medium">
                        {getTranslation("alumni.read_more", currentLang)}
                      </span>
                    </div>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>
  </div>
</BaseLayout>
